<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="utng.gtid232.jjcm.ListaOrdenesController"
      prefWidth="1100" prefHeight="700"
      style="-fx-background-color: #EBEBEB; -fx-padding: 20;" spacing="12">

    <Label text="Órdenes de servicio"
           style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
    <Separator/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="txtBuscar" promptText="Buscar orden..."
                   prefWidth="400" prefHeight="32"/>
        <ComboBox fx:id="cmbFiltroEstado" promptText="Todos los estados"
                  prefWidth="180" prefHeight="32"/>
        <Button text="Buscar"      onAction="#onBuscar"      prefHeight="32"/>
        <Button text="Actualizar"  onAction="#onActualizar"  prefHeight="32"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Crear nueva orden" onAction="#onCrearOrden" prefHeight="32"/>
    </HBox>

    <TableView fx:id="tablaOrdenes" VBox.vgrow="ALWAYS"
               style="-fx-border-color: #cccccc; -fx-border-width: 1;">
        <columns>
            <TableColumn fx:id="colNumero"      text="No. Orden"   prefWidth="110"/>
            <TableColumn fx:id="colCliente"     text="Cliente"     prefWidth="160"/>
            <TableColumn fx:id="colDescripcion" text="Descripción" prefWidth="220"/>
            <TableColumn fx:id="colTecnico"     text="Técnico"     prefWidth="130"/>
            <TableColumn fx:id="colFecha"       text="Fecha"       prefWidth="100"/>
            <TableColumn fx:id="colEstado"      text="Estado"      prefWidth="110"/>
        </columns>
        <placeholder><Label text="No hay órdenes registradas"/></placeholder>
    </TableView>

    <HBox spacing="8" alignment="CENTER_RIGHT">
        <Button text="Ver detalle"  onAction="#onDetalle" prefWidth="130"/>
        <Button text="Editar orden" onAction="#onEditar"  prefWidth="120"/>
        <Button text="Eliminar"     onAction="#onEliminar" prefWidth="100"/>
    </HBox>
</VBox>
