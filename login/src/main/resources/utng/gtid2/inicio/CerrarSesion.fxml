<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="utng.gtid2.inicio.CerrarSesionController"
      fx:id="rootPane"
      prefWidth="420" prefHeight="220"
      alignment="CENTER"
      style="-fx-background-color: #EBEBEB; -fx-padding: 30;" spacing="16">

    <Label text="Cerrar sesión"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <Label text="¿Estás seguro de que deseas cerrar sesión?"
           wrapText="true" textAlignment="CENTER"
           style="-fx-font-size: 13px;"/>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Cancelar"
                onAction="#onCancelar"
                prefWidth="120"/>
        <Button text="Sí, cerrar sesión"
                onAction="#onConfirmarCerrarSesion"
                prefWidth="150"/>
    </HBox>
</VBox>
