<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="780.0" prefWidth="1140.0" style="-fx-background-color: #2b2b2b;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="utng.gtid2.inicio.EquiposController">

    <BorderPane fx:id="rootPane" layoutX="20.0" layoutY="112.8" prefHeight="647.0" prefWidth="1021.0" style="-fx-background-color: #f3f3f3;" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="99.0" AnchorPane.topAnchor="113.0">

        <!-- ===================== HEADER ===================== -->
        <top>
            <VBox spacing="14.0" BorderPane.alignment="CENTER">
                <padding>
                    <Insets bottom="0.0" left="24.0" right="24.0" top="20.0" />
                </padding>

                <Label text="Gestión de Equipos" textFill="#222222">
                    <font>
                        <javafx.scene.text.Font name="System Bold" size="22.0" />
                    </font>
                </Label>

                <!-- Barra de búsqueda / filtros / acción principal -->
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <TextField fx:id="txtBuscar" prefHeight="32.0" prefWidth="370.0" promptText="Buscar por nombre o código..." style="-fx-background-color: white; -fx-border-color: #c9c9c9; -fx-border-radius: 3; -fx-background-radius: 3;" />

                    <Label text="Estado:" textFill="#333333" />
                    <ComboBox fx:id="cmbEstado" prefHeight="32.0" prefWidth="150.0" style="-fx-background-color: #e9e9e9; -fx-border-color: #c9c9c9; -fx-border-radius: 3; -fx-background-radius: 3;" />

                    <Region HBox.hgrow="ALWAYS" />

                    <Button fx:id="btnRegistrarEquipo" mnemonicParsing="false" onAction="#abrirRegistrar" prefHeight="32.0" style="-fx-background-color: #8fc1da; -fx-border-color: #5e9bbd; -fx-border-radius: 3; -fx-background-radius: 3; -fx-text-fill: #1c1c1c; -fx-font-weight: bold; -fx-cursor: hand;" text="Registrar equipo" />
                </HBox>
            </VBox>
        </top>

        <!-- ===================== TABLA ===================== -->
        <center>
            <VBox BorderPane.alignment="CENTER">
                <padding>
                    <Insets bottom="0.0" left="24.0" right="24.0" top="16.0" />
                </padding>

                <TableView fx:id="tablaEquipos" prefHeight="540.0" style="-fx-border-color: #c9c9c9;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                        <TableColumn fx:id="colCodigo" prefWidth="120.0" text="Código" />
                        <TableColumn fx:id="colNombre" prefWidth="230.0" text="Nombre" />
                        <TableColumn fx:id="colTipo" prefWidth="170.0" text="Tipo" />
                        <TableColumn fx:id="colResponsable" prefWidth="190.0" text="Responsable" />
                        <TableColumn fx:id="colEstado" prefWidth="75.20001220703125" text="Estado" />
                        <TableColumn fx:id="colFechaRegistro" prefWidth="123.20002441406245" text="Fecha registro" />
                    </columns>
                    <placeholder>
                        <Label text="No content in table" />
                    </placeholder>
                </TableView>
            </VBox>
        </center>

        <!-- ===================== FOOTER ===================== -->
        <bottom>
            <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #f3f3f3;" BorderPane.alignment="CENTER">
                <padding>
                    <Insets bottom="18.0" left="24.0" right="24.0" top="12.0" />
                </padding>

                <Label fx:id="lblEquipoSeleccionado" text="Ningún equipo seleccionado" textFill="#333333" />

                <Region HBox.hgrow="ALWAYS" />

                <Button fx:id="btnEditarEquipo" disable="true" mnemonicParsing="false" onAction="#abrirEditarEquipo" prefHeight="32.0" prefWidth="120.0" style="-fx-background-color: #e9e9e9; -fx-border-color: #040404; -fx-border-radius: 3; -fx-background-radius: 3;" text="Editar equipo" textFill="#0a0a0a" />
                <Button fx:id="btnDarBaja" disable="true" mnemonicParsing="false" onAction="#abrirBaja" prefHeight="32.0" prefWidth="110.0" style="-fx-background-color: #e9e9e9; -fx-border-color: #020202; -fx-border-radius: 3; -fx-background-radius: 3;" text="Dar de baja" textFill="#0a0a0a" />
                <Button fx:id="btnVerHistorial" disable="true" mnemonicParsing="false" onAction="#abrirVerHistorial" prefHeight="32.0" prefWidth="120.0" style="-fx-background-color: #e9e9e9; -fx-border-color: #000000; -fx-border-radius: 3; -fx-background-radius: 3;" text="Ver historial" textFill="#0a0a0a" />
            </HBox>
        </bottom>

    </BorderPane>
</AnchorPane>
