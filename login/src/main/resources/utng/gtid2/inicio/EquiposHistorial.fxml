<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="rootPane" prefHeight="560.0" prefWidth="700.0" style="-fx-background-color: #2b2b2b;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="utng.gtid2.cmjam.EquiposHistorialController">

   <!-- ===================== HEADER ===================== -->
   <top>
      <VBox spacing="14.0" style="-fx-background-color: #f3f3f3;" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="14.0" left="24.0" right="24.0" top="20.0" />
         </padding>
         <children>
            <HBox alignment="CENTER_LEFT" spacing="12.0">
               <children>
                  <Button fx:id="btnRegresar" mnemonicParsing="false" onAction="#regresar" prefHeight="32.0" style="-fx-background-color: #e9e9e9; -fx-border-color: #c9c9c9; -fx-border-radius: 3; -fx-background-radius: 3; -fx-cursor: hand;" text="&lt; Regresar" textFill="#333333" />
                  <Label text="Historial del equipo" textFill="#222222">
                     <font>
                        <Font name="System Bold" size="22.0" />
                     </font>
                  </Label>
                  <Region HBox.hgrow="ALWAYS" />
                  <Label fx:id="lblEquipoHistorial" text="Equipo: --" textFill="#777777" />
               </children>
            </HBox>
         </children>
      </VBox>
   </top>

   <!-- ===================== TABLA DE HISTORIAL ===================== -->
   <center>
      <VBox style="-fx-background-color: #f3f3f3;" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="16.0" left="24.0" right="24.0" top="16.0" />
         </padding>
         <children>

            <TableView fx:id="tablaHistorial" style="-fx-border-color: #c9c9c9;" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colFecha" prefWidth="110.0" text="Fecha" />
                  <TableColumn fx:id="colEvento" prefWidth="150.0" text="Evento" />
                  <TableColumn fx:id="colResponsable" prefWidth="160.0" text="Responsable" />
                  <TableColumn fx:id="colDetalle" prefWidth="226.0" text="Detalle" />
               </columns>
               <placeholder>
                  <Label text="Sin historial registrado" />
               </placeholder>
            </TableView>

         </children>
      </VBox>
   </center>

</BorderPane>
