<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="utng.gtid2.inicio.ListaInventarioController"
      prefWidth="1100" prefHeight="700"
      style="-fx-background-color: #EBEBEB; -fx-padding: 20;" spacing="12">

    <Label text="Gestión de inventario"
           style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
    <Separator/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="txtBuscar" promptText="Buscar material..."
                   prefWidth="500" prefHeight="32"/>
        <Button text="Buscar" onAction="#onBuscar" prefHeight="32"/>
        <Button text="Actualizar" onAction="#onActualizar" prefHeight="32"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Registrar nuevo material" onAction="#onAgregar" prefHeight="32"/>
    </HBox>

    <TableView fx:id="tablaInventario" VBox.vgrow="ALWAYS"
               style="-fx-border-color: #cccccc; -fx-border-width: 1;">
        <columns>
            <TableColumn fx:id="colId"        text="ID"               prefWidth="60"/>
            <TableColumn fx:id="colCodigo"    text="Código"           prefWidth="100"/>
            <TableColumn fx:id="colNombre"    text="Nombre"           prefWidth="220"/>
            <TableColumn fx:id="colCategoria" text="Categoría"        prefWidth="120"/>
            <TableColumn fx:id="colStock"     text="Stock"            prefWidth="80"/>
            <TableColumn fx:id="colEstado"    text="Estado"           prefWidth="110"/>
            <TableColumn fx:id="colFecha"     text="Fecha de registro" prefWidth="140"/>
        </columns>
        <placeholder><Label text="No hay materiales registrados"/></placeholder>
    </TableView>

    <HBox spacing="8" alignment="CENTER_RIGHT">
        <Button text="Ver detalle"       onAction="#onDetalle"  prefWidth="120"/>
        <Button text="Editar material"   onAction="#onEditar"   prefWidth="140"/>
        <Button text="Eliminar material" onAction="#onEliminar" prefWidth="150"/>
    </HBox>
</VBox>
