<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="utng.gtid2.inicio.MenuPerfilController"
      fx:id="rootPane"
      prefWidth="900" prefHeight="650"
      style="-fx-background-color: #EBEBEB; -fx-padding: 20;" spacing="10">

    <Label text="Perfil de usuario"
           style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <Separator>
        <VBox.margin><Insets top="4" bottom="10"/></VBox.margin>
    </Separator>

    <VBox spacing="10"
          style="-fx-background-color: white; -fx-padding: 20;
                 -fx-border-color: #cccccc; -fx-border-width: 1;">
        <HBox alignment="CENTER_LEFT" spacing="14">
            <Label text="Usuario:"
                   style="-fx-font-weight: bold; -fx-min-width: 120;"/>
            <Label text="Carlos Méndez"/>
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="14">
            <Label text="Correo:"
                   style="-fx-font-weight: bold; -fx-min-width: 120;"/>
            <Label text="carlos@correo.com"/>
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="14">
            <Label text="Rol:"
                   style="-fx-font-weight: bold; -fx-min-width: 120;"/>
            <Label text="Administrador"/>
        </HBox>
    </VBox>

    <Region VBox.vgrow="ALWAYS"/>

    <HBox spacing="8" alignment="CENTER_RIGHT">
        <Button text="Ver perfil"         onAction="#onVerPerfil"        prefWidth="130"/>
        <Button text="Editar perfil"      onAction="#onEditarPerfil"     prefWidth="130"/>
        <Button text="Cambiar contraseña" onAction="#onCambiarPassword"  prefWidth="160"/>
        <Button text="Cerrar sesión"      onAction="#onCerrarSesion"     prefWidth="130"/>
    </HBox>
</VBox>
