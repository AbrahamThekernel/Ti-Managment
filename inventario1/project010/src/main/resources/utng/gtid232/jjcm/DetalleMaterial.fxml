<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="utng.gtid232.jjcm.DetalleMaterialController"
      prefWidth="700" prefHeight="580"
      style="-fx-background-color: #EBEBEB; -fx-padding: 20;" spacing="12">

    <Label text="Detalle del material"
           style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
    <Separator/>

    <GridPane hgap="16" vgap="12"
              style="-fx-background-color: white; -fx-padding: 20;
                     -fx-border-color: #cccccc; -fx-border-width: 1;">

        <Label text="Código:"            style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Label fx:id="lblCodigo"                                        GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Nombre:"            style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <Label fx:id="lblNombre"                                        GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Categoría:"         style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <Label fx:id="lblCategoria"                                     GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="Unidad:"            style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <Label fx:id="lblUnidad"                                        GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Label text="Stock actual:"      style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <Label fx:id="lblStock"                                         GridPane.columnIndex="1" GridPane.rowIndex="4"/>

        <Label text="Stock mínimo:"      style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <Label fx:id="lblStockMin"                                      GridPane.columnIndex="1" GridPane.rowIndex="5"/>

        <Label text="Precio unitario:"   style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
        <Label fx:id="lblPrecio"                                        GridPane.columnIndex="1" GridPane.rowIndex="6"/>

        <Label text="Proveedor:"         style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
        <Label fx:id="lblProveedor"                                     GridPane.columnIndex="1" GridPane.rowIndex="7"/>

        <Label text="Estado:"            style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="8"/>
        <Label fx:id="lblEstado"                                        GridPane.columnIndex="1" GridPane.rowIndex="8"/>

        <Label text="Fecha de registro:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="9"/>
        <Label fx:id="lblFecha"                                         GridPane.columnIndex="1" GridPane.rowIndex="9"/>

        <Label text="Descripción:"       style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="10"/>
        <Label fx:id="lblDescripcion"    wrapText="true"                GridPane.columnIndex="1" GridPane.rowIndex="10"/>

        <columnConstraints>
            <ColumnConstraints minWidth="160" prefWidth="160"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>
    </GridPane>

    <Region VBox.vgrow="ALWAYS"/>

    <HBox spacing="8" alignment="CENTER_RIGHT">
        <Button text="Regresar"         onAction="#onVolver"  prefWidth="100"/>
        <Button text="Editar material"  onAction="#onEditar"  prefWidth="140"/>
    </HBox>
</VBox>
