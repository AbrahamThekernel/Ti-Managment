<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="rootPane" prefHeight="560.0" prefWidth="700.0" style="-fx-background-color: #2b2b2b;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="utng.gtid2.cmjam.ConfiguracionRolesController">

   <!-- ===================== HEADER ===================== -->
   <top>
      <VBox spacing="14.0" style="-fx-background-color: #f3f3f3;" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="14.0" left="24.0" right="24.0" top="20.0" />
         </padding>
         <children>
            <HBox alignment="CENTER_LEFT" spacing="12.0">
               <children>
                  <Button fx:id="btnRegresar" mnemonicParsing="false" onAction="#regresar" prefHeight="32.0" style="-fx-background-color: #e9e9e9; -fx-border-color: #c9c9c9; -fx-border-radius: 3; -fx-background-radius: 3; -fx-cursor: hand;" text="&lt; Regresar" textFill="#333333" />
                  <Label text="Roles y permisos" textFill="#222222">
                     <font>
                        <Font name="System Bold" size="22.0" />
                     </font>
                  </Label>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnNuevoRol" mnemonicParsing="false" onAction="#abrirNuevoRol" prefHeight="32.0" style="-fx-background-color: #8fc1da; -fx-border-color: #5e9bbd; -fx-border-radius: 3; -fx-background-radius: 3; -fx-text-fill: #1c1c1c; -fx-font-weight: bold; -fx-cursor: hand;" text="Nuevo rol" />
               </children>
            </HBox>
         </children>
      </VBox>
   </top>

   <!-- ===================== TABLA DE ROLES ===================== -->
   <center>
      <VBox style="-fx-background-color: #f3f3f3;" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="16.0" left="24.0" right="24.0" top="16.0" />
         </padding>
         <children>

            <TableView fx:id="tablaRoles" style="-fx-border-color: #c9c9c9;" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colRol" prefWidth="150.0" text="Rol" />
                  <TableColumn fx:id="colDescripcion" prefWidth="260.0" text="Descripción" />
                  <TableColumn fx:id="colUsuariosAsignados" prefWidth="120.0" text="Usuarios" />
                  <TableColumn fx:id="colPermisos" prefWidth="110.0" text="Permisos" />
               </columns>
               <placeholder>
                  <Label text="No hay roles registrados" />
               </placeholder>
            </TableView>

         </children>
      </VBox>
   </center>

   <!-- ===================== FOOTER ===================== -->
   <bottom>
      <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #f3f3f3;" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="18.0" left="24.0" right="24.0" top="12.0" />
         </padding>
         <children>
            <Label fx:id="lblRolSeleccionado" text="Ningún rol seleccionado" textFill="#333333" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnEditarRol" disable="true" mnemonicParsing="false" prefHeight="32.0" prefWidth="120.0" style="-fx-background-color: #e9e9e9; -fx-border-color: #c9c9c9; -fx-border-radius: 3; -fx-background-radius: 3;" text="Editar rol" textFill="#9a9a9a" />
            <Button fx:id="btnEliminarRol" disable="true" mnemonicParsing="false" prefHeight="32.0" prefWidth="120.0" style="-fx-background-color: #e9e9e9; -fx-border-color: #c9c9c9; -fx-border-radius: 3; -fx-background-radius: 3;" text="Eliminar rol" textFill="#9a9a9a" />
         </children>
      </HBox>
   </bottom>

</BorderPane>
